# ============================================================
# Paperboy Configuration
# Copy this file to .env and fill in your values
# ============================================================

# === Debug Mode ===
# Set to true for full pipeline tracing (IMAP, LLM, SMTP)
# Also available as CLI flag: python -m src.main --debug
DEBUG=false

# === Gmail (IMAP + SMTP) ===
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# Leave empty or remove to read ALL emails from INBOX
# Set to a Gmail label name (e.g. Newsletters) to only read that label
GMAIL_LABEL=
LOOKBACK_HOURS=24

# === LLM Provider ===
# Options: qwen / openai / deepseek / ollama
LLM_PROVIDER=qwen

# === Qwen (DashScope) ===
QWEN_API_KEY=sk-your-dashscope-api-key
QWEN_MODEL=qwen-plus

# === OpenAI (optional) ===
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# === DeepSeek (optional) ===
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# === Ollama (optional, local) ===
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5

# === Agent Behavior ===
MAX_AGENT_TURNS=3
MAX_EMAIL_PREVIEW_CHARS=500

# ============================================================
# X/Twitter Tech Hotspot Source
# ============================================================

# Enable Twitter pipeline
TWITTER_ENABLED=true

# Tech topics to track (comma-separated, max 10)
# Leave empty for broad tech defaults (AI Agent, LLM, machine learning, Python, software engineering)
# Example: AI Agent,quantitative trading,embodied intelligence,brain-computer interface,protein engineering
TWITTER_TOPICS=AI Agent,quantitative trading,embodied intelligence,brain-computer interface,editable protein

# Time window for fetching tweets (hours)
TWITTER_LOOKBACK_HOURS=24

# How many top tweets to fetch per topic (pre-filter by engagement)
TWITTER_TOP_PER_TOPIC=20

# Final number of curated tweets in the briefing (Agent picks the best)
TWITTER_FINAL_TOP=10

# === Scraper Channel 1: twscrape (recommended, highest priority) ===
# Format: username:password:email:email_password (comma-separated for multiple accounts)
# Get accounts at: https://github.com/vladkens/twscrape
TWSCRAPE_ACCOUNTS=

# === Scraper Channel 2: Nitter RSS (no auth, public instances) ===
# Comma-separated Nitter instance URLs. Leave empty to use built-in defaults.
# Find instances at: https://github.com/zedeus/nitter/wiki/Instances
NITTER_INSTANCES=

# === Scraper Channel 3: Official X API v2 (free tier, rate limited) ===
# Get your Bearer Token at: https://developer.twitter.com/
TWITTER_BEARER_TOKEN=
