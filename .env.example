# ============================================================
# Paperboy Configuration
# Copy this file to .env and fill in your values
# ============================================================

# === Debug Mode ===
# Set to true for full pipeline tracing (IMAP, LLM, SMTP)
# Also available as CLI flag: python -m src.main --debug
DEBUG=false

# === Gmail (IMAP + SMTP) ===
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
GMAIL_LABEL=Newsletters
LOOKBACK_HOURS=24

# === LLM Provider ===
# Options: qwen / openai / deepseek / ollama
LLM_PROVIDER=qwen

# === Qwen (DashScope) ===
QWEN_API_KEY=sk-your-dashscope-api-key
QWEN_MODEL=qwen-plus

# === OpenAI (optional) ===
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# === DeepSeek (optional) ===
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# === Ollama (optional, local) ===
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5

# === Agent Behavior ===
MAX_AGENT_TURNS=3
MAX_EMAIL_PREVIEW_CHARS=500
